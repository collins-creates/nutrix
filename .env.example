# Server Configuration
PORT=3000
NODE_ENV=production

# USDA FoodData Central API
USDA_API_KEY=nYLm8TmWUTuVDoFUgm94P4FkKnPfgrdEexKnfURV
USDA_BASE_URL=https://api.nal.usda.gov/fdc/v1

# Redis Configuration (Optional - falls back to in-memory cache)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SEARCH_RATE_LIMIT_WINDOW_MS=60000
SEARCH_RATE_LIMIT_MAX_REQUESTS=30
AUTOCOMPLETE_RATE_LIMIT_WINDOW_MS=60000
AUTOCOMPLETE_RATE_LIMIT_MAX_REQUESTS=60

# CORS Configuration
FRONTEND_URL=https://nutrix.vercel.app

# Security Configuration
HELMET_ENABLED=true
CORS_ENABLED=true
COMPRESSION_ENABLED=true

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Cache Configuration
CACHE_TTL_SECONDS=3600
SEARCH_CACHE_TTL_SECONDS=1800

# Gemini AI (Optional)
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-1.5-flash

# Vercel Configuration
VERCEL_ENV=production
VERCEL_REGION=us-east-1
